# Database
DATABASE_URL="postgresql://user:password@localhost:5432/polyodin"

# Redis/KV
KV_URL="redis://localhost:6379"
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
KV_REST_API_READ_ONLY_TOKEN=""

# JWT
JWT_SECRET="your-jwt-secret-at-least-32-chars-long"
JWT_REFRESH_SECRET="your-refresh-secret-at-least-32-chars"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# SendGrid
SENDGRID_API_KEY="SG..."
FROM_EMAIL="noreply@polyodin.com"

# Sentry
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_SENTRY_DSN=""

# Polymarket
POLYMARKET_API_URL="https://gamma-api.polymarket.com"
POLYMARKET_CLOB_URL="https://clob.polymarket.com"
POLYMARKET_PRIVATE_KEY=""

# App
NEXT_PUBLIC_APP_URL="https://polyodin.com"
NEXT_PUBLIC_WS_URL="wss://polyodin.com"
NEXT_PUBLIC_CHAIN_ID="137"
NODE_ENV="production"

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# Cookie Session
SESSION_SECRET="your-session-secret-at-least-32-chars"

# CORS
ALLOWED_ORIGINS="https://polyodin.com,https://www.polyodin.com"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"
